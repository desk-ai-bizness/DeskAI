# DeskAI Backend Environment Variables
#
# In dev/test: all vars have sensible defaults, only DESKAI_ENV is needed.
# In prod/staging: all vars marked REQUIRED must be set explicitly.

# Environment (dev|staging|prod|test)
DESKAI_ENV=dev

# Contract version
DESKAI_CONTRACT_VERSION=v1

# --- REQUIRED in prod/staging ---

# DynamoDB table name for consultation records
DESKAI_DYNAMODB_TABLE=deskai-dev-consultation-records

# S3 bucket for consultation artifacts (audio, transcripts)
DESKAI_ARTIFACTS_BUCKET=deskai-dev-artifacts

# Secrets Manager secret names (name only, value in AWS console)
DESKAI_ELEVENLABS_SECRET_NAME=deskai/dev/elevenlabs
DESKAI_CLAUDE_SECRET_NAME=deskai/dev/claude
DESKAI_COGNITO_CLIENT_SECRET_NAME=deskai/dev/cognito

# Cognito User Pool identifiers
DESKAI_COGNITO_USER_POOL_ID=us-east-1_EXAMPLE
DESKAI_COGNITO_CLIENT_ID=example-client-id

# WebSocket API URL for real-time consultation streaming
DESKAI_WEBSOCKET_URL=wss://localhost:3001

# --- Optional (have safe defaults) ---

# DynamoDB UI config key
DESKAI_UI_CONFIG_KEY=CONFIG#ui

# Session duration limit in minutes
DESKAI_MAX_SESSION_DURATION_MINUTES=60
