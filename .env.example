# DeskAI Root Environment Variables
#
# In dev/test: defaults are used. In prod/staging: backend vars are REQUIRED.

# Shared defaults
DESKAI_ENV=dev
DESKAI_CONTRACT_VERSION=v1

# Frontend-facing base URLs
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:9000

# Backend service references (REQUIRED in prod/staging)
DESKAI_DYNAMODB_TABLE=deskai-dev-consultation-records
DESKAI_ARTIFACTS_BUCKET=deskai-dev-artifacts
DESKAI_UI_CONFIG_KEY=CONFIG#ui

# Secret references (name only, value stays in AWS Secrets Manager)
DESKAI_ELEVENLABS_SECRET_NAME=deskai/dev/elevenlabs
DESKAI_CLAUDE_SECRET_NAME=deskai/dev/claude
DESKAI_COGNITO_CLIENT_SECRET_NAME=deskai/dev/cognito

# Cognito (REQUIRED in prod/staging)
DESKAI_COGNITO_USER_POOL_ID=us-east-1_EXAMPLE
DESKAI_COGNITO_CLIENT_ID=example-client-id

# WebSocket API URL (REQUIRED in prod/staging)
DESKAI_WEBSOCKET_URL=wss://localhost:3001
